---
import { AppConfig } from "../../data";
---

<section class="Slide UIComponentsSlide">
    <div class="container-fluid">
        <div class="header">
            <h2 class="title">UI Components</h2>
        </div>
        <div class="content">
            <div class="buttons-wrapper">
                <p class="content-title">Buttons</p>
                <div class="buttons">
                    <button>START A PROJECT →</button>
                    <button>LEARN MORE</button>
                    <button>See our Process →</button>
                </div>
                <p class="description">Buttons use uppercase labels, 0.06em tracking, border-radius: 3px (deliberately tight — not the generic 8px pill). Accent color is reserved for primary conversion actions only.</p>
            </div>

            <div class="badges-pills">
                <p class="content-title">Badges</p>
                <div class="badges">
                    <span>Services</span>
                    <span>New</span>
                    <span>React Native</span>
                </div>

                <p class="content-title">Pills</p>
                <div class="pills">
                    <span>Success</span>
                    <span>Pending</span>
                </div>
            </div>

            <div class="form-elements">
                <p class="content-title">Form Elements</p>
                <form action="">
                    <div class="inputs-group">
                        <label for="name">Full Name</label>
                        <input type="text" name="name" id="name" placeholder="Jane Doe" />
                    </div>

                    <div class="inputs-group">
                        <label for="yob">Year of Birth</label>
                        <input type="number" name="yob" id="yob" placeholder="1999" />
                    </div>
                </form>
            </div>

            <div class="card-elements">
                <p class="content-title">Card Patterns</p>
                <div class="card">
                    <div class="header">
                        <p>01. Services</p>
                    </div>

                    <div class="body">
                        <p>Web Application Development</p>
                    </div>

                    <div class="footer">
                        <p>From customer portals to full SaaS platforms</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
