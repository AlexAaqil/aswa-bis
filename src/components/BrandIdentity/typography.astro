---
import { AppConfig } from "../../data";
---

<section class="Slide TypographiesSlide">
    <div class="container-fluid">
        <div class="header">
            <h2 class="title">Typography</h2>
        </div>
        <div class="content">
            <div class="typographies">
                <div class="typography">
                    <div class="header">
                        <p class="heading font-accent">Helvetica</p>
                        <p class="sub-heading">Elegant · Editorial</p>                        
                    </div>
                    <p class="bold font-bold">Bold - headings</p>
                    <p class="description">---</p>
                </div>

                <div class="typography">
                    <div class="header">
                        <p class="heading">Sans Serif</p>
                        <p class="sub-heading">Bold · Structural · Everything upright</p>
                    </div>
                    <p class="light">Light - body, copy, descriptions.</p>
                    <p class="semibold font-semibold">Semi Bold - labels, secondary UI.</p>
                    <p class="bold font-bold">Bold - buttons, nav, strong UI.</p>
                    <p class="description">Confident, modern, quietly engineered. Carries weight without shouting.</p>
                </div>
            </div>
        </div>
    </div>
</section>
