---
import { AppConfig } from "../../data";
---

<section class="Slide">
    <div class="container-fluid">
        <div class="content">
            <p class="content-title">Our Core Values: </p>
            <p>The principles that guide every decision — from how we build to how we communicate.</p>
            <ol class="core-values grid-ol">
                <li>
                    <span class="value">Innovation</span>
                    <span class="description">We embrace new tools and approaches to solve old problems in ways that actually work for African businesses.</span>
                </li>
                <li>
                    <span class="value">Reliability</span>
                    <span class="description">We deliver on what we promise — on time, to spec, and with measurable outcomes businesses can count on.</span>
                </li>
                <li>
                    <span class="value">Simplicity</span>
                    <span class="description">We make complexity disappear. Technology should feel easy, not overwhelming for business owners.</span>
                </li>
                <li>
                    <span class="value">Growth</span>
                    <span class="description">Everything we do is measured by one thing: did it help the business grow? That's our only benchmark.</span>
                </li>
            </ol>
        </div>
    </div>
</section>
