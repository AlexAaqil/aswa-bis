---
import { AppConfig } from "../../data";
---

<section class="Slide">
    <div class="container-fluid">
        <div class="header">
            <h2 class="title">Competitor Comparison</h2>
        </div>
        <div class="content">
            <table class="table">
                <thead>
                    <tr>
                        <th>What matters to clients</th>
                        <th>Generic agencies</th>
                        <th>Freelancers</th>
                        <th>Big Tech firms</th>
                        <th>DIY Platform</th>
                        <th>{ AppConfig.brand_name }</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Results are the goal, not the deliverable</td>
                        <td>Rarely</td>
                        <td>Rarely</td>
                        <td>Sometimes</td>
                        <td>Never</td>
                        <td>Always</td>
                    </tr>
                    <tr>
                        <td>Strategy + execution in the same team</td>
                        <td>Split</td>
                        <td>No</td>
                        <td>Yes</td>
                        <td>No</td>
                        <td>Yes</td>
                    </tr>
                    <tr>
                        <td>Affordable for growing businesses</td>
                        <td>Usually</td>
                        <td>Yes</td>
                        <td>No</td>
                        <td>Yes</td>
                        <td>Yes</td>
                    </tr>
                    <tr>
                        <td>Consistent, reliable quality</td>
                        <td>Usually</td>
                        <td>Varies</td>
                        <td>Yes</td>
                        <td>Limited</td>
                        <td>Yes</td>
                    </tr>
                    <tr>
                        <td>Fast turnaround without cutting corners</td>
                        <td>Slow</td>
                        <td>Fast</td>
                        <td>Slow</td>
                        <td>Fast</td>
                        <td>Fast</td>
                    </tr>
                    <tr>
                        <td>Accountable to your growth, not just the brief</td>
                        <td>No</td>
                        <td>No</td>
                        <td>No</td>
                        <td>No</td>
                        <td>Core Promise</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
