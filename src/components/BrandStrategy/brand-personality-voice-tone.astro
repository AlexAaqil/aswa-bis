---
import { AppConfig } from "../../data";
---

<section class="Slide">
    <div class="container-fluid">
        <div class="header">
            <h2 class="title">Brand Voice & Tone</h2>
        </div>
        <div class="content">
            <p class="content-title">Brand Voice</p>
            <p>Our voice is</p>
            <ol class="pills">
                <li>Direct</li>
                <li>Confident, not arrogant</li>
                <li>Professional</li>
                <li>Approachable</li>
                <li>Expert</li>
            </ol>

            <p class="content-title">The Golden Rule</p>
            <p>Sound like the smartest, most confident person in the room — who also makes everyone else feel like they could be. Never showy. Never jargon. Always connected to results.</p>

            <p class="content-title">Tone by context</p>
            <ol class="grid-ol">
                <li>
                    <span>Social</span>
                    <span>Short, punchy, direct, strong opinions. Questions that cut.</span>
                </li>
                <li>
                    <span>Proposals</span>
                    <span>Precise, structured, every claim backed by logic.</span>
                </li>
                <li>
                    <span>Client comms</span>
                    <span>Professionally warm, never condescending. Always on their level.</span>
                </li>
            </ol>
        </div>
    </div>
</section>
